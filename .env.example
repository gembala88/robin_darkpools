# Copy to .env and fill. .env is gitignored — NEVER commit real keys/RPC.

# Wallet that owns the executor + pays gas
PRIVATE_KEY=0xyour_private_key_here

# Deployed ArbExecutor address (set after `npm run deploy`)
EXECUTOR_ADDR=

# Live trading toggle (1 = trade, 0 = monitor only)
LIVE=0

# --- RPC ---
# Dedicated execution RPC (Alchemy/dRPC). Private — keep out of git. Used for the
# actual trade txs (reliable). If empty, EXEC path falls back to the monitor RPC.
EXEC_RPC_URL=
# Monitor RPC override. If empty, uses the public Robinhood RPC with the built-in
# DNS-block bypass (Cloudflare IP pin + DoH) — no VPN needed.
RPC_URL=

# --- strategy ---
WATCHLIST=1              # 1 = watch every token in watchlist.json (npm run scan)
MIN_SIZE_ETH=0.002       # optimal-size search lower bound
MAX_SIZE_ETH=0.005       # upper bound (cap capital at risk per fill)
MIN_PROFIT_BPS=150       # required net edge after fees + gas
SLIPPAGE_BPS=100
GRID_POINTS=3            # geometric probe sizes per direction
POLL_MS=45000            # fallback poll (bot is mainly event-driven)
EVENT_POLL_MS=6000       # Swap-event getLogs cadence
GAS_UNITS=700000
RPC_CONCURRENCY=3        # max in-flight on the fallback pinned provider

# --- Telegram notifications (bot must be /start-ed by the recipient first) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
