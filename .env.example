# .env — SECRETS ONLY. All tuning numbers live in user-config.json (safe to edit).
# Copy to .env and fill. .env is gitignored — NEVER commit real keys.

# --- LIVE TRADING (keep =0 / blank until ready) ---
PRIVATE_KEY=
EXECUTOR_ADDR=
LIVE=0

# --- RPC ---
EXEC_RPC_URL=https://rpc.mainnet.chain.robinhood.com/
RPC_URL=

# --- Screener vars (ONLY secrets; number tuning in user-config.json) ---
# BUY_EVENT_SIG=Buy(address,address,uint256,uint256,uint256,uint256)
# SELL_EVENT_SIG=Sell(address,address,uint256,uint256,uint256,uint256)
# SCREENER_SCAN_V4=1

# --- LLM (default: NVIDIA NIM free tier; set LLM_PROVIDER=claude for Claude) ---
# Get NVIDIA key: https://build.nvidia.com/ — free tier available
NVIDIA_API_KEY=
# LLM_PROVIDER=nvidia
# LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# CLAUDE_API_KEY=sk-ant-...

# --- Telegram — Arb Bot (arb.js trade notifications, uses TELEGRAM_BOT_TOKEN) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Telegram — Screener Bot (screener + commands, uses SCREENER_BOT_TOKEN) ---
# /status /top /token commands — SCREENER_CHAT_ID is your private chat with the bot
SCREENER_BOT_TOKEN=
SCREENER_CHAT_ID=
# Optional broadcast channel (e.g. public channel). All notifications go to BOTH
# SCREENER_CHAT_ID AND SCREENER_CHANNEL_ID if set. Commands only in SCREENER_CHAT_ID.
SCREENER_CHANNEL_ID=

# --- Optional env overrides for user-config.json (env always wins) ---
# Prefix with SCREENER_ for screener tunables, e.g.:
# SCREENER_POLL_MS=5000
# SCREENER_REFRESH_SEC=60
# SCREENER_SCAN_CHUNK=200000   (blocks per chunk during historical scan)
# SCREENER_SCAN_DELAY=300      (ms delay between chunks)
# SCREENER_MAX_RETRY=30000     (max backoff ms on 429)
